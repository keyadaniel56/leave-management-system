@startuml Use Case Diagram

left to right direction

actor Employee
actor Admin

rectangle "Leave Management System" {

  usecase "Register / Login" as UC1
  usecase "View Dashboard" as UC2
  usecase "Apply for Leave" as UC3
  usecase "View Leave History" as UC4
  usecase "Cancel Leave Request" as UC5

  usecase "Manage Users" as UC6
  usecase "View All Leave Requests" as UC7
  usecase "Approve Leave" as UC8
  usecase "Reject Leave" as UC9
  usecase "View Reports / Stats" as UC10
}

Employee --> UC1
Employee --> UC2
Employee --> UC3
Employee --> UC4
Employee --> UC5

Admin --> UC1
Admin --> UC2
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC9
Admin --> UC10

@enduml
